# All values have sensible defaults — copy to .env only if you need to override.

# API server port (backend)
PORT=3001

# Base URL the web console uses to reach the API (browser-side).
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Shared API key for the (demo-only) auth layer. The login form pre-fills the
# default below so the app can be evaluated with zero setup — override it for
# any non-demo use. The CLI reads the same variable.
KDO_API_KEY=kdo-dev-key-2026
