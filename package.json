{
  "name": "k8s-deploy-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "A Kubernetes deployment orchestrator with progressive rollout, health gating, and automatic rollback.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "nx run-many --target=dev --all --parallel=10",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "lint": "nx run-many --target=lint --all",
    "verify": "nx run-many --target=typecheck,test,build --all"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "nx": "^20.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "nx", "sharp"]
  }
}
